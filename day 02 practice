print(type(a))
b=int(b)
print(type(b))
c=int(c)
print(type(c))
d=bool(d)
print(type(d))
e=tuple(e)
print(type(e))
f=list(f)
print(type(f))
g=dict(g)
print(type(g))
h=set(h)
print(type(h))
print(b)
print(c)
print(d)
print(e)
print(f)
print(g)
print(h)

