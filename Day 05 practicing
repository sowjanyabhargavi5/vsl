# =====================================
# Nested Loops in Python
# =====================================

print("NESTED LOOPS IN PYTHON\n")

# A nested loop means a loop inside another loop.

# -------------------------------------
# Example 1: Number Pattern
# -------------------------------------

print("Example 1: Number Pattern")

for row in range(1, 4):          # Outer loop
    for column in range(1, 4):   # Inner loop
        print(column, end=" ")
    print()

print()

# -------------------------------------
# Example 2: Multiplication Table
# -------------------------------------

print("Example 2: Multiplication Table")

for i in range(1, 4):
    for j in range(1, 6):
        print(i * j, end="\t")
    print()

print()

# -------------------------------------
# Example 3: Star Pattern
# -------------------------------------

print("Example 3: Star Pattern")

rows = int(input("Enter number of rows: "))

for i in range(1, rows + 1):
    for j in range(i):
        print("*", end=" ")
    print()

print()

# -------------------------------------
# Example 4: Coordinate Pairs
# -------------------------------------

print("Example 4: Coordinate Pairs")

for x in range(1, 4):
    for y in range(1, 3):
        print(f"({x},{y})")

print("\nProgram Completed Successfully!")


